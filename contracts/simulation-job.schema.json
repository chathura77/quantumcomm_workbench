{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantumcomm-workbench.local/schemas/simulation-job.schema.json",
  "title": "Simulation Job",
  "type": "object",
  "required": ["id", "toolId", "createdAt", "input"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "toolId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "modelVersion": {
      "type": "string"
    },
    "input": {
      "type": "object",
      "additionalProperties": true
    },
    "result": {
      "type": "object",
      "additionalProperties": true
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message", "severity"],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "critical"]
          }
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
